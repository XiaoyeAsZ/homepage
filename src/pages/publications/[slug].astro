---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { publications } from "@/data/publications";
import { pathFor } from "@/utils/paths";

export function getStaticPaths() {
  return publications.map((paper) => ({
    params: { slug: paper.slug },
    props: { paper },
  }));
}

const { paper } = Astro.props;
const Content = paper.Content;
---

<BaseLayout title={paper.title} description={paper.venue}>
  <section class="page-header publication-detail-header">
    <a
      class="back-link"
      data-back-link
      href={pathFor("/publications/")}
    >
      Back
    </a>
    <h1>{paper.title}</h1>
    <p>{paper.authors}</p>
    <p>{paper.venue}</p>
  </section>

  <section class="section">
    <article class="publication-detail">
      <div class="publication-detail-meta">
        <span class="meta">{paper.date}</span>
        {
          paper.topics.length > 0 && (
            <div class="topic-list" aria-label="Publication topics">
              {paper.topics.map((topic) => (
                <span class:list={["topic-pill", `topic-pill-${topic.level}`]}>
                  {topic.name}
                </span>
              ))}
            </div>
          )
        }
      </div>

      {
        paper.links.length > 0 && (
          <div class="pub-links">
            {paper.links.map((link) => (
              <a href={link.href}>{link.label}</a>
            ))}
          </div>
        )
      }

      <div class="entry-content publication-body">
        <Content />
      </div>
    </article>
  </section>
</BaseLayout>

<script>
  const backLink = document.querySelector<HTMLAnchorElement>("[data-back-link]");

  backLink?.addEventListener("click", (event) => {
    if (!document.referrer) {
      return;
    }

    const referrer = new URL(document.referrer);

    if (referrer.origin !== window.location.origin) {
      return;
    }

    event.preventDefault();
    window.history.back();
  });
</script>
