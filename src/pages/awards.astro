---
import PageHeader from "@/components/PageHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { awards } from "@/data/awards";
---

<BaseLayout title="Awards" description="Lab awards and recognition">
  <PageHeader
    title="Awards"
  />
  <section class="section">
    {
      awards.map((award) => {
        const Content = award.Content;
        return (
          <article class="award">
            <div class="meta">{award.year}</div>
            <div>
              <h2>{award.title}</h2>
              <div class="entry-content">
                <Content />
              </div>
            </div>
          </article>
        );
      })
    }
  </section>
</BaseLayout>
