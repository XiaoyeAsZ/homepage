---
import PageHeader from "@/components/PageHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { awards } from "@/data/awards";

const monthNames = [
  "January",
  "February",
  "March",
  "April",
  "May",
  "June",
  "July",
  "August",
  "September",
  "October",
  "November",
  "December",
];

const awardsByMonth = awards.reduce<Record<string, typeof awards>>(
  (groups, award) => {
    const month = award.fullDate.slice(0, 7);
    groups[month] = groups[month] ?? [];
    groups[month].push(award);
    return groups;
  },
  {},
);

const awardMonths = Object.entries(awardsByMonth).sort(([a], [b]) => b.localeCompare(a));

const formatMonth = (month: string) => {
  const [year, monthNumber] = month.split("-");
  return `${monthNames[Number(monthNumber) - 1]} ${year}`;
};
---

<BaseLayout title="Awards" description="Lab awards and recognition">
  <PageHeader
    title="Awards"
  />
  <section class="section">
    <div class="month-list">
      {
        awardMonths.map(([month, awardsInMonth]) => (
          <section class={`month-group month-accent-${month.slice(5, 7)}`} aria-labelledby={`awards-${month}`}>
            <h2 class="month-heading" id={`awards-${month}`}>{formatMonth(month)}</h2>
            <div class="entry-card-list">
              {awardsInMonth.map((award) => {
                const Content = award.Content;
                return (
                  <article class="award entry-card award-card">
                    <div class="meta">{award.date}</div>
                    <div>
                      <h3>{award.title}</h3>
                      <div class="entry-content">
                        <Content />
                      </div>
                    </div>
                  </article>
                );
              })}
            </div>
          </section>
        ))
      }
    </div>
  </section>
</BaseLayout>
