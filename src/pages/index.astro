---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { awards } from "@/data/awards";
import { lab } from "@/data/lab";
import { news } from "@/data/news";
import { publications } from "@/data/publications";
import { topics } from "@/data/topics";
import { pathFor } from "@/utils/paths";

const usedTopicIds = new Set(publications.flatMap((paper) => paper.topics.map((topic) => topic.id)));
const publicationTopics = topics.filter((topic) => usedTopicIds.has(topic.id));
const visibleTopicCount = 12;
const visiblePublicationCount = 4;
const hasHiddenPublicationTopics = publicationTopics.length > visibleTopicCount;
const hasHiddenPublications = publications.length > visiblePublicationCount;
---

<BaseLayout title={lab.name} description={lab.description}>
  <section class="section intro-section">
    <div class="intro-grid">
      <div>
        <h1>About Us</h1>
        <p class="lead">{lab.description}</p>
        <p>{lab.tagline}</p>
        <div class="hero-actions">
          <a class="button" href={pathFor("/publications/")}
            >View Publications</a
          >
          <button class="button secondary" type="button" data-join-open>
            Join Us
          </button>
        </div>
      </div>
      <figure class="research-visual">
        <img
          src={pathFor("/research-summary-transparent.png")}
          alt="Visual summary of the lab research areas"
          width="1096"
          height="971"
        />
      </figure>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <h2>Latest News</h2>
      </div>
      <a class="link" href={pathFor("/news/")}>All news</a>
    </div>
    <div class="grid three">
      {
        news.slice(0, 3).map((item) => (
          <article class="card home-card">
            <div class="meta">{item.date}</div>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section alt">
    <div class="section-panel">
      <div class="section-heading">
        <div>
          <h2>Featured Publications</h2>
        </div>
        <a class="link" href={pathFor("/publications/")}>All publications</a>
      </div>
      <div class="publication-filter-list" aria-label="Publication topics">
        <button
          class="publication-filter is-active"
          type="button"
          data-publication-filter="all"
          aria-pressed="true"
        >
          All
        </button>
        {
          publicationTopics.map((topic, index) => (
            <button
              class:list={[
                "publication-filter",
                `research-chip-${topic.type}`,
              ]}
              type="button"
              data-publication-filter={topic.id}
              data-topic-filter
              data-topic-index={index}
              aria-pressed="false"
              hidden={index >= visibleTopicCount}
            >
              {topic.name}
            </button>
          ))
        }
      </div>
      {
        hasHiddenPublicationTopics && (
          <button
            class="filter-toggle"
            type="button"
            data-topic-toggle
            aria-expanded="false"
          >
            Show more topics
          </button>
        )
      }
      <div class="home-publication-grid" data-publication-list>
        {
          publications.map((paper, index) => (
            <article
              class="home-publication-card"
              data-publication-card
              data-publication-index={index}
              data-topic-ids={paper.topics.map((topic) => topic.id).join(" ")}
              hidden={index >= visiblePublicationCount}
            >
              <div class="meta">{paper.date}</div>
              <h3>{paper.title}</h3>
              <p>{paper.authors}</p>
              <p>{paper.venue}</p>
              {
                paper.topics.length > 0 && (
                  <div class="topic-list compact-topic-list" aria-label="Publication topics">
                    {paper.topics.slice(0, 4).map((topic) => (
                      <span class:list={["topic-pill", `topic-pill-${topic.type}`]}>
                        {topic.name}
                      </span>
                    ))}
                  </div>
                )
              }
            </article>
          ))
        }
      </div>
      <p class="publication-empty" data-publication-empty hidden>
        No publications match this topic yet.
      </p>
      {
        hasHiddenPublications && (
          <button
            class="filter-toggle publication-list-toggle"
            type="button"
            data-publication-toggle
            aria-expanded="false"
          >
            Show more publications
          </button>
        )
      }
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <h2>Awards</h2>
      </div>
      <a class="link" href={pathFor("/awards/")}>All awards</a>
    </div>
    <div class="grid two">
      {
        awards.slice(0, 3).map((award) => (
          <article class="card home-card">
            <div class="meta">{award.date}</div>
            <h3>{award.title}</h3>
            <p>{award.description}</p>
          </article>
        ))
      }
    </div>
  </section>

  <div class="modal-backdrop" data-join-modal aria-hidden="true">
    <section
      class="join-modal"
      role="dialog"
      aria-modal="true"
      aria-labelledby="join-modal-title"
    >
      <button class="modal-close" type="button" aria-label="Close" data-join-close>
        &times;
      </button>
      <div>
        <div class="meta">Join Us</div>
        <h2 id="join-modal-title">Work With Us</h2>
        <p>
          We welcome students and collaborators interested in efficient AI
          systems, compilers, computer architecture, and algorithms.
        </p>
      </div>
      <div class="join-modal-grid">
        <article>
          <h3>Graduate Students</h3>
          <p>
            Prospective PhD and master students can send a CV, transcript, and
            a short note about research interests.
          </p>
        </article>
        <article>
          <h3>Undergraduates</h3>
          <p>
            Undergraduate researchers are welcome to start from paper reading,
            artifact reproduction, and focused implementation projects.
          </p>
        </article>
        <article>
          <h3>Collaborators</h3>
          <p>
            We are open to academic and industry collaborations around AI
            acceleration, model serving, CAD, and compiler infrastructure.
          </p>
        </article>
      </div>
      <div class="join-modal-actions">
        <a class="button" href={`mailto:${lab.email}`}>Contact Us</a>
        <a class="button secondary" href={pathFor("/team/")}>View Team</a>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  const publicationFilters =
    document.querySelectorAll<HTMLButtonElement>("[data-publication-filter]");
  const topicFilters =
    document.querySelectorAll<HTMLButtonElement>("[data-topic-filter]");
  const publicationCards =
    document.querySelectorAll<HTMLElement>("[data-publication-card]");
  const publicationEmpty =
    document.querySelector<HTMLElement>("[data-publication-empty]");
  const topicToggle =
    document.querySelector<HTMLButtonElement>("[data-topic-toggle]");
  const publicationToggle =
    document.querySelector<HTMLButtonElement>("[data-publication-toggle]");
  const visibleTopicLimit = 12;
  const visiblePublicationLimit = 4;
  let selectedPublicationTopic = "all";
  let topicsExpanded = false;
  let publicationsExpanded = false;

  function updateTopicVisibility() {
    topicFilters.forEach((filter) => {
      const index = Number(filter.dataset.topicIndex ?? "0");
      filter.hidden = !topicsExpanded && index >= visibleTopicLimit;
    });

    if (topicToggle) {
      topicToggle.textContent = topicsExpanded ? "Hide topics" : "Show more topics";
      topicToggle.setAttribute("aria-expanded", String(topicsExpanded));
    }
  }

  function setActivePublicationFilter(activeFilter: HTMLButtonElement) {
    publicationFilters.forEach((item) => {
      const isActive = item === activeFilter;
      item.classList.toggle("is-active", isActive);
      item.setAttribute("aria-pressed", String(isActive));
    });
  }

  function updatePublicationVisibility() {
    let renderedCount = 0;

    publicationCards.forEach((card) => {
      const topics = card.dataset.topicIds?.split(" ") ?? [];
      const matchesTopic =
        selectedPublicationTopic === "all" || topics.includes(selectedPublicationTopic);
      const withinLimit = publicationsExpanded || renderedCount < visiblePublicationLimit;
      const isVisible = matchesTopic && withinLimit;

      if (matchesTopic) {
        renderedCount += 1;
      }

      card.hidden = !isVisible;
    });

    if (publicationEmpty) {
      publicationEmpty.hidden = renderedCount > 0;
    }

    if (publicationToggle) {
      publicationToggle.hidden = renderedCount <= visiblePublicationLimit;
      publicationToggle.textContent = publicationsExpanded
        ? "Hide publications"
        : "Show more publications";
      publicationToggle.setAttribute("aria-expanded", String(publicationsExpanded));
    }
  }

  publicationFilters.forEach((filter) => {
    filter.addEventListener("click", () => {
      selectedPublicationTopic = filter.dataset.publicationFilter ?? "all";
      publicationsExpanded = false;
      setActivePublicationFilter(filter);
      updatePublicationVisibility();
    });
  });

  topicToggle?.addEventListener("click", () => {
    topicsExpanded = !topicsExpanded;

    if (!topicsExpanded) {
      const activeHiddenFilter = Array.from(topicFilters).find(
        (filter) =>
          filter.classList.contains("is-active") &&
          Number(filter.dataset.topicIndex ?? "0") >= visibleTopicLimit,
      );

      if (activeHiddenFilter) {
        const allFilter = document.querySelector<HTMLButtonElement>(
          '[data-publication-filter="all"]',
        );
        selectedPublicationTopic = "all";
        publicationsExpanded = false;
        if (allFilter) {
          setActivePublicationFilter(allFilter);
        }
        updatePublicationVisibility();
      }
    }

    updateTopicVisibility();
  });

  publicationToggle?.addEventListener("click", () => {
    publicationsExpanded = !publicationsExpanded;
    updatePublicationVisibility();
  });

  updateTopicVisibility();
  updatePublicationVisibility();

  const joinModal =
    document.querySelector<HTMLElement>("[data-join-modal]");
  const joinOpen =
    document.querySelector<HTMLButtonElement>("[data-join-open]");
  const joinClose =
    document.querySelector<HTMLButtonElement>("[data-join-close]");

  function openJoinModal() {
    joinModal?.classList.add("is-open");
    joinModal?.setAttribute("aria-hidden", "false");
    document.body.classList.add("modal-open");
    joinClose?.focus();
  }

  function closeJoinModal() {
    joinModal?.classList.remove("is-open");
    joinModal?.setAttribute("aria-hidden", "true");
    document.body.classList.remove("modal-open");
    joinOpen?.focus();
  }

  joinOpen?.addEventListener("click", openJoinModal);
  joinClose?.addEventListener("click", closeJoinModal);
  joinModal?.addEventListener("click", (event) => {
    if (event.target === joinModal) {
      closeJoinModal();
    }
  });

  window.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && joinModal?.classList.contains("is-open")) {
      closeJoinModal();
    }
  });
</script>
