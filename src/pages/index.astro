---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { awards } from "@/data/awards";
import { lab } from "@/data/lab";
import { news } from "@/data/news";
import { publications } from "@/data/publications";
import { pathFor } from "@/utils/paths";

const visibleResearchCount = 4;
const hasHiddenResearchAreas = lab.researchAreas.length > visibleResearchCount;
---

<BaseLayout title={lab.name} description={lab.description}>
  <section class="section intro-section">
    <div class="intro-grid">
      <div>
        <h1>About Us</h1>
        <p class="lead">{lab.description}</p>
        <p>{lab.tagline}</p>
        <div
          class="research-list"
          id="research-list"
          aria-label="Research areas"
        >
          {
            lab.researchAreas.map((area, index) => (
              <span
                class:list={[
                  "research-chip",
                  `research-chip-${area.type}`,
                  index >= visibleResearchCount && "research-extra",
                ]}
              >
                {area.name}
              </span>
            ))
          }
        </div>
        {
          hasHiddenResearchAreas && (
            <button
              class="research-toggle"
              type="button"
              aria-expanded="false"
              aria-controls="research-list"
            >
              Show more
            </button>
          )
        }
        <div class="hero-actions">
          <a class="button" href={pathFor("/publications/")}
            >View Publications</a
          >
          <a class="button secondary" href={pathFor("/team/")}>Meet the Team</a>
        </div>
      </div>
      <figure class="research-visual">
        <img
          src={pathFor("/research-summary.png")}
          alt="Visual summary of the lab research areas"
          width="960"
          height="960"
        />
      </figure>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <h2>Latest News</h2>
      </div>
      <a class="link" href={pathFor("/news/")}>All news</a>
    </div>
    <div class="grid three">
      {
        news.slice(0, 3).map((item) => (
          <article class="card">
            <div class="meta">{item.date}</div>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section alt">
    <div class="section-panel">
      <div class="section-heading">
        <div>
          <h2>Featured Publications</h2>
        </div>
        <a class="link" href={pathFor("/publications/")}>All publications</a>
      </div>
      <div>
        {
          publications.slice(0, 4).map((paper) => (
            <article class="publication">
              <div class="meta">{paper.date}</div>
              <div>
                <h3>
                  <a href={pathFor(`/publications/${paper.slug}/`)}>
                    {paper.title}
                  </a>
                </h3>
                <p>{paper.authors}</p>
                <p>{paper.venue}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <h2>Awards</h2>
      </div>
      <a class="link" href={pathFor("/awards/")}>All awards</a>
    </div>
    <div class="grid two">
      {
        awards.slice(0, 3).map((award) => (
          <article class="card">
            <div class="meta">{award.date}</div>
            <h3>{award.title}</h3>
            <p>{award.description}</p>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>

<script>
  const researchList = document.querySelector("#research-list");
  const researchToggle =
    document.querySelector<HTMLButtonElement>(".research-toggle");

  researchToggle?.addEventListener("click", () => {
    const expanded = researchList?.classList.toggle("is-expanded") ?? false;

    researchToggle.setAttribute("aria-expanded", String(expanded));
    researchToggle.textContent = expanded ? "Hide" : "Show more";
  });
</script>
