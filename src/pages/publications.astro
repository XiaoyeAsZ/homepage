---
import PageHeader from "@/components/PageHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { publications } from "@/data/publications";
---

<BaseLayout title="Publications" description="Lab publications">
  <PageHeader
    title="Publications"
  />
  <section class="section">
    {
      publications.map((paper) => {
        const Content = paper.Content;
        return (
          <article class="publication">
            <div class="meta">{paper.year}</div>
            <div>
              <h2>{paper.title}</h2>
              <p>{paper.authors}</p>
              <p>{paper.venue}</p>
              <div class="entry-content">
                <Content />
              </div>
              <div class="pub-links">
                {paper.links.map((link) => <a href={link.href}>{link.label}</a>)}
              </div>
            </div>
          </article>
        );
      })
    }
  </section>
</BaseLayout>
