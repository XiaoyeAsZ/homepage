---
import PageHeader from "@/components/PageHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { news } from "@/data/news";
---

<BaseLayout title="News" description="Lab news and announcements">
  <PageHeader
    title="News"
  />
  <section class="section">
    <div class="timeline">
      {
        news.map((item) => (
          <article class="card">
            <div class="meta">{item.date}</div>
            <h2>{item.title}</h2>
            <p>{item.body}</p>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
