---
import PageHeader from "@/components/PageHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { teamSections } from "@/data/team";

const teamMembers = teamSections.flatMap((section) => section.members);
---

<BaseLayout title="Team" description="Lab members">
  <PageHeader
    title="Team"
  />
  <section class="section">
    {
      teamSections.map((section) => (
        <section class="team-section" aria-labelledby={`team-${section.title.toLowerCase().replaceAll(" ", "-")}`}>
          <div class="team-section-heading">
            <h2 id={`team-${section.title.toLowerCase().replaceAll(" ", "-")}`}>{section.title}</h2>
          </div>
          <div class="grid three team-grid">
            {
              section.members.map((person) => {
                return (
                  <article
                    class="card person member-card"
                    role="button"
                    tabindex="0"
                    data-member-open={person.slug}
                    aria-controls={`member-modal-${person.slug}`}
                  >
                    <img src={person.avatar} alt={`${person.name} portrait`} width="413" height="579" />
                    <div>
                      <h3>{person.name}</h3>
                      <div class="meta">{person.role} · Joined {person.date.slice(0, 7)}</div>
                    </div>
                  </article>
                );
              })
            }
          </div>
        </section>
      ))
    }
  </section>

  {
    teamMembers.map((person) => {
      const Content = person.Content;
      return (
        <div
          class="modal-backdrop"
          id={`member-modal-${person.slug}`}
          data-member-modal={person.slug}
          aria-hidden="true"
        >
          <article
            class="member-modal"
            role="dialog"
            aria-modal="true"
            aria-labelledby={`member-modal-title-${person.slug}`}
          >
            <button class="modal-close" type="button" aria-label="Close" data-member-close>
              &times;
            </button>
            <div class="member-modal-content">
              <img
                class="member-modal-avatar"
                src={person.avatar}
                alt={`${person.name} portrait`}
                width="413"
                height="579"
              />
              <div class="member-modal-detail">
                <h2 id={`member-modal-title-${person.slug}`}>{person.name}</h2>
                <div class="member-meta-row">
                  <span>{person.role}</span>
                  <span>Joined {person.date.slice(0, 7)}</span>
                </div>
                {
                  (person.email || person.phone) && (
                    <div class="member-contact-list" aria-label={`${person.name} contact`}>
                      {person.email && (
                        <a href={`mailto:${person.email}`}>
                          <svg aria-hidden="true" viewBox="0 0 24 24">
                            <path d="M4 6h16v12H4z" />
                            <path d="m4 7 8 6 8-6" />
                          </svg>
                          <span>{person.email}</span>
                        </a>
                      )}
                      {person.phone && (
                        <a href={`tel:${person.phone.replaceAll(" ", "")}`}>
                          <svg aria-hidden="true" viewBox="0 0 24 24">
                            <path d="M7 4h4l2 5-3 2a12 12 0 0 0 5 5l2-3 5 2v4c0 1-1 2-2 2A17 17 0 0 1 3 6c0-1 1-2 2-2h2z" />
                          </svg>
                          <span>{person.phone}</span>
                        </a>
                      )}
                    </div>
                  )
                }
                {
                  person.links.length > 0 && (
                    <div class="member-links" aria-label={`${person.name} links`}>
                      {person.links.map((link) => (
                        <a href={link.href} target="_blank" rel="noreferrer">
                          {link.label}
                        </a>
                      ))}
                    </div>
                  )
                }
                <div class="entry-content member-modal-body">
                  <Content />
                </div>
              </div>
            </div>
          </article>
        </div>
      );
    })
  }
</BaseLayout>

<script>
  const memberOpeners = document.querySelectorAll<HTMLElement>("[data-member-open]");
  const memberModals = document.querySelectorAll<HTMLElement>("[data-member-modal]");
  let activeMemberOpener: HTMLElement | null = null;

  function getMemberModal(slug: string) {
    return Array.from(memberModals).find(
      (modal) => modal.dataset.memberModal === slug,
    );
  }

  function openMemberModal(slug: string, opener: HTMLElement) {
    const modal = getMemberModal(slug);

    if (!modal) {
      return;
    }

    activeMemberOpener = opener;
    modal.classList.add("is-open");
    modal.setAttribute("aria-hidden", "false");
    document.body.classList.add("modal-open");
    modal.querySelector<HTMLButtonElement>("[data-member-close]")?.focus();
  }

  function closeMemberModal(modal: HTMLElement) {
    modal.classList.remove("is-open");
    modal.setAttribute("aria-hidden", "true");
    document.body.classList.remove("modal-open");
    activeMemberOpener?.focus();
    activeMemberOpener = null;
  }

  memberOpeners.forEach((opener) => {
    opener.addEventListener("click", (event) => {
      const target = event.target as HTMLElement;

      if (target.closest("a")) {
        return;
      }

      openMemberModal(opener.dataset.memberOpen ?? "", opener);
    });

    opener.addEventListener("keydown", (event) => {
      if (event.key !== "Enter" && event.key !== " ") {
        return;
      }

      event.preventDefault();
      openMemberModal(opener.dataset.memberOpen ?? "", opener);
    });
  });

  memberModals.forEach((modal) => {
    modal.querySelector("[data-member-close]")?.addEventListener("click", () => {
      closeMemberModal(modal);
    });

    modal.addEventListener("click", (event) => {
      if (event.target === modal) {
        closeMemberModal(modal);
      }
    });
  });

  window.addEventListener("keydown", (event) => {
    if (event.key !== "Escape") {
      return;
    }

    const openModal = Array.from(memberModals).find((modal) =>
      modal.classList.contains("is-open"),
    );

    if (openModal) {
      closeMemberModal(openModal);
    }
  });
</script>
