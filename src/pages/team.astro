---
import PageHeader from "@/components/PageHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { team } from "@/data/lab";
import { pathFor } from "@/utils/paths";
---

<BaseLayout title="Team" description="Lab members">
  <PageHeader
    eyebrow="People"
    title="Team"
    intro="Add faculty, students, staff, visitors, alumni, and collaborators."
  />
  <section class="section">
    <div class="grid three">
      {
        team.map((person) => (
          <article class="card person">
            <img src={pathFor(person.image)} alt={`${person.name} portrait placeholder`} width="480" height="480" />
            <div>
              <h2>{person.name}</h2>
              <div class="meta">{person.role}</div>
              <p>{person.bio}</p>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
