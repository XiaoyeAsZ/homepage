---
import PageHeader from "@/components/PageHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { teamSections } from "@/data/team";
import { pathFor } from "@/utils/paths";
---

<BaseLayout title="Team" description="Lab members">
  <PageHeader
    title="Team"
  />
  <section class="section">
    {
      teamSections.map((section) => (
        <section class="team-section" aria-labelledby={`team-${section.title.toLowerCase().replaceAll(" ", "-")}`}>
          <div class="team-section-heading">
            <h2 id={`team-${section.title.toLowerCase().replaceAll(" ", "-")}`}>{section.title}</h2>
            <p>{section.description}</p>
          </div>
          <div class="grid three">
            {section.members.map((person) => (
              <article class="card person">
                <img src={pathFor(person.image)} alt={`${person.name} portrait placeholder`} width="480" height="480" />
                <div>
                  <h3>{person.name}</h3>
                  <div class="meta">{person.role}</div>
                  <p>{person.bio}</p>
                </div>
              </article>
            ))}
          </div>
        </section>
      ))
    }
  </section>
</BaseLayout>
