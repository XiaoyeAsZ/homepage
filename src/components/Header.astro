---
import { lab } from "@/data/lab";
import { pathFor } from "@/utils/paths";

const nav = [
  { href: "/", label: "Home" },
  { href: "/news/", label: "News" },
  { href: "/publications/", label: "Publications" },
  { href: "/awards/", label: "Awards" },
  { href: "/team/", label: "Team" },
  { href: "/course/", label: "Courses" },
  { href: "/join/", label: "Join Us" },
];

const path = Astro.url.pathname;
---

<header class="site-header">
  <a class="brand" href={pathFor("/")}>
    <span class="brand-mark" aria-hidden="true">L</span>
    <span>{lab.name}</span>
  </a>
  <nav aria-label="Primary navigation">
    {
      nav.map((item) => {
        const resolved = pathFor(item.href);
        const active =
          item.href === "/" ? path === resolved : path.startsWith(resolved);
        return (
          <a href={resolved} aria-current={active ? "page" : undefined}>
            {item.label}
          </a>
        );
      })
    }
  </nav>
</header>

<script>
  const mobileHeaderQuery = window.matchMedia("(max-width: 820px)");
  let lastScrollY = window.scrollY;
  let ticking = false;

  function updateHeaderVisibility() {
    const currentScrollY = Math.max(window.scrollY, 0);
    const scrollingDown = currentScrollY > lastScrollY + 4;
    const scrollingUp = currentScrollY < lastScrollY - 4;

    if (!mobileHeaderQuery.matches || currentScrollY < 96 || scrollingUp) {
      document.body.classList.remove("header-hidden");
    } else if (scrollingDown) {
      document.body.classList.add("header-hidden");
    }

    lastScrollY = currentScrollY;
    ticking = false;
  }

  function requestHeaderUpdate() {
    if (!ticking) {
      window.requestAnimationFrame(updateHeaderVisibility);
      ticking = true;
    }
  }

  window.addEventListener("scroll", requestHeaderUpdate, { passive: true });
  mobileHeaderQuery.addEventListener("change", () => {
    document.body.classList.remove("header-hidden");
    lastScrollY = window.scrollY;
  });
</script>
