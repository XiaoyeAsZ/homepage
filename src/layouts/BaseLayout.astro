---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { lab } from "@/data/lab";
import { pathFor } from "@/utils/paths";
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const { title = lab.name, description = lab.description } = Astro.props;
const pageTitle = title === lab.name ? title : `${title} | ${lab.name}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={pathFor("/favicon.svg")} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
